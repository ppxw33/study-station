.846154 13.814889 \n&quot;,&#x000A;       &quot;L 190.441352 13.5 \n&quot;,&#x000A;       &quot;L 192.036549 13.814896 \n&quot;,&#x000A;       &quot;L 193.631746 14.753328 \n&quot;,&#x000A;       &quot;L 195.226944 16.296758 \n&quot;,&#x000A;       &quot;L 196.822141 18.415173 \n&quot;,&#x000A;       &quot;L 198.417338 21.068279 \n&quot;,&#x000A;       &quot;L 200.012536 24.207097 \n&quot;,&#x000A;       &quot;L 201.607733 27.775848 \n&quot;,&#x000A;       &quot;L 203.20293 31.713935 \n&quot;,&#x000A;       &quot;L 206.393325 40.44372 \n&quot;,&#x000A;       &quot;L 211.178916 54.732931 \n&quot;,&#x000A;       &quot;L 215.964509 69.133646 \n&quot;,&#x000A;       &quot;L 219.154904 78.235198 \n&quot;,&#x000A;       &quot;L 222.345298 86.681345 \n&quot;,&#x000A;       &quot;L 225.535693 94.349061 \n&quot;,&#x000A;       &quot;L 228.726088 101.185068 \n&quot;,&#x000A;       &quot;L 231.916484 107.189056 \n&quot;,&#x000A;       &quot;L 235.106879 112.397409 \n&quot;,&#x000A;       &quot;L 238.297271 116.869579 \n&quot;,&#x000A;       &quot;L 241.487666 120.677302 \n&quot;,&#x000A;       &quot;L 244.678061 123.89682 \n&quot;,&#x000A;       &quot;L 247.868457 126.603296 \n&quot;,&#x000A;       &quot;L 251.058848 128.867818 \n&quot;,&#x000A;       &quot;L 254.249243 130.755216 \n&quot;,&#x000A;       &quot;L 257.439635 132.323237 \n&quot;,&#x000A;       &quot;L 260.630034 133.622466 \n&quot;,&#x000A;       &quot;L 263.820426 134.696712 \n&quot;,&#x000A;       &quot;L 267.010825 135.583359 \n&quot;,&#x000A;       &quot;L 271.79642 136.629496 \n&quot;,&#x000A;       &quot;L 276.582007 137.410223 \n&quot;,&#x000A;       &quot;L 281.367594 137.991793 \n&quot;,&#x000A;       &quot;L 287.748385 138.54229 \n&quot;,&#x000A;       &quot;L 295.724372 138.98448 \n&quot;,&#x000A;       &quot;L 306.89075 139.328718 \n&quot;,&#x000A;       &quot;L 316.461932 139.482212 \n&quot;,&#x000A;       &quot;L 316.461932 139.482212 \n&quot;,&#x000A;       &quot;\&quot; clip-path=\&quot;url(#p1bf0ffa52c)\&quot; style=\&quot;fill: none; stroke: #1f77b4; stroke-width: 1.5; stroke-linecap: square\&quot;/&gt;\n&quot;,&#x000A;       &quot;   &lt;/g&gt;\n&quot;,&#x000A;       &quot;   &lt;g id=\&quot;patch_3\&quot;&gt;\n&quot;,&#x000A;       &quot;    &lt;path d=\&quot;M 50.14375 145.8 \n&quot;,&#x000A;       &quot;L 50.14375 7.2 \n&quot;,&#x000A;       &quot;\&quot; style=\&quot;fill: none; stroke: #000000; stroke-width: 0.8; stroke-linejoin: miter; stroke-linecap: square\&quot;/&gt;\n&quot;,&#x000A;       &quot;   &lt;/g&gt;\n&quot;,&#x000A;       &quot;   &lt;g id=\&quot;patch_4\&quot;&gt;\n&quot;,&#x000A;       &quot;    &lt;path d=\&quot;M 329.14375 145.8 \n&quot;,&#x000A;       &quot;L 329.14375 7.2 \n&quot;,&#x000A;       &quot;\&quot; style=\&quot;fill: none; stroke: #000000; stroke-width: 0.8; stroke-linejoin: miter; stroke-linecap: square\&quot;/&gt;\n&quot;,&#x000A;       &quot;   &lt;/g&gt;\n&quot;,&#x000A;       &quot;   &lt;g id=\&quot;patch_5\&quot;&gt;\n&quot;,&#x000A;       &quot;    &lt;path d=\&quot;M 50.14375 145.8 \n&quot;,&#x000A;       &quot;L 329.14375 145.8 \n&quot;,&#x000A;       &quot;\&quot; style=\&quot;fill: none; stroke: #000000; stroke-width: 0.8; stroke-linejoin: miter; stroke-linecap: square\&quot;/&gt;\n&quot;,&#x000A;       &quot;   &lt;/g&gt;\n&quot;,&#x000A;       &quot;   &lt;g id=\&quot;patch_6\&quot;&gt;\n&quot;,&#x000A;       &quot;    &lt;path d=\&quot;M 50.14375 7.2 \n&quot;,&#x000A;       &quot;L 329.14375 7.2 \n&quot;,&#x000A;       &quot;\&quot; style=\&quot;fill: none; stroke: #000000; stroke-width: 0.8; stroke-linejoin: miter; stroke-linecap: square\&quot;/&gt;\n&quot;,&#x000A;       &quot;   &lt;/g&gt;\n&quot;,&#x000A;       &quot;  &lt;/g&gt;\n&quot;,&#x000A;       &quot; &lt;/g&gt;\n&quot;,&#x000A;       &quot; &lt;defs&gt;\n&quot;,&#x000A;       &quot;  &lt;clipPath id=\&quot;p1bf0ffa52c\&quot;&gt;\n&quot;,&#x000A;       &quot;   &lt;rect x=\&quot;50.14375\&quot; y=\&quot;7.2\&quot; width=\&quot;279\&quot; height=\&quot;138.6\&quot;/&gt;\n&quot;,&#x000A;       &quot;  &lt;/clipPath&gt;\n&quot;,&#x000A;       &quot; &lt;/defs&gt;\n&quot;,&#x000A;       &quot;&lt;/svg&gt;\n&quot;&#x000A;      ],&#x000A;      &quot;text/plain&quot;: [&#x000A;       &quot;&lt;Figure size 500x250 with 1 Axes&gt;&quot;&#x000A;      ]&#x000A;     },&#x000A;     &quot;metadata&quot;: {},&#x000A;     &quot;output_type&quot;: &quot;display_data&quot;&#x000A;    }&#x000A;   ],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;# 清除以前的梯度\n&quot;,&#x000A;    &quot;#x.grad：PyTorch 会把 x 的梯度（导数）存在 x.grad 这个属性里，第一次计算梯度前它是 None，但如果之前算过其他梯度（比如 ReLU 的梯度），x.grad 里会有旧值；\n&quot;,&#x000A;    &quot;#.data：访问 x.grad 张量的 “原始数值部分”（新手可以暂时理解为 “必须加这一步才能清空”）；\n&quot;,&#x000A;    &quot;#.zero_()：这是 PyTorch 的 “原地清零” 函数（函数名末尾的 _ 表示 “原地修改”，不创建新张量），把 x.grad 里的所有元素都变成 0。\n&quot;,&#x000A;    &quot;x.grad.data.zero_()\n&quot;,&#x000A;    &quot;# 让 PyTorch 自动算出 ReLU 输出 y 对输入 x 的导数（梯度），并把结果存在 x.grad 里。\n&quot;,&#x000A;    &quot;y.backward(torch.ones_like(x),retain_graph=True)\n&quot;,&#x000A;    &quot;d2l.plot(x.detach(), x.grad, &#39;x&#39;, &#39;grad of sigmoid&#39;, figsize=(5, 2.5))&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;markdown&quot;,&#x000A;   &quot;id&quot;: &quot;f2c210b5&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;source&quot;: [&#x000A;    &quot;### tanh函数\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;与sigmoid函数类似，\n&quot;,&#x000A;    &quot;[**tanh(双曲正切)函数也能将其输入压缩转换到区间(-1, 1)上**]。\n&quot;,&#x000A;    &quot;tanh函数的公式如下：\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;(**$$\\operatorname{tanh}(x) = \\frac{1 - \\exp(-2x)}{1 + \\exp(-2x)}.$$**)\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;下面我们绘制tanh函数。\n&quot;,&#x000A;    &quot;注意，当输入在0附近时，tanh函数接近线性变换。\n&quot;,&#x000A;    &quot;函数的形状类似于sigmoid函数，\n&quot;,&#x000A;    &quot;不同的是tanh函数关于坐标系原点中心对称。\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;tanh 函数（双曲正切函数）是深度学习中经典的激活函数，核心作用是把任意实数映射到 -1~1 之间，解决了 Sigmoid 函数 “输出非 0 均值” 的问题，\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;The tanh Function(Hyperbolic Tangent)is a classic activation function in deep learning.Its core function is to moap any real number to the range between -1~1.Crucially,it solves the \&quot;non-zero-centered output\&quot;problem associated with the Sigmoid function.\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;tanh 能用来干啥？\n&quot;,&#x000A;    &quot;隐藏层激活函数：在 ReLU 普及前，tanh 是比 Sigmoid 更常用的隐藏层激活函数 —— 因为输出是 0 均值，反向传播时梯度更新更高效（不会像 Sigmoid 那样梯度全正 / 全负）；\n&quot;,&#x000A;    &quot;序列模型（如 RNN）：早期 RNN、LSTM 中常用来处理时序数据，平衡正负值的表达；\n&quot;,&#x000A;    &quot;注意：输出层很少用—— 输出层做二分类用 Sigmoid（0~1 表示概率），做多分类用 Softmax，tanh 一般只用于隐藏层。\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;Activation Function for Hidden Layers: Before ReLU became ubiquitous, tanh was more commonly used in hidden layers than Sigmoid. This is because its zero-centered output leads to more efficient gradient updates during backpropagation (avoiding the \&quot;all positive/all negative\&quot; gradient issue seen in Sigmoid).\n&quot;,&#x000A;    &quot;Sequence Models (e.g., RNNs): It is frequently used in early RNNs and LSTMs for processing sequential data, as it effectively balances the representation of positive and negative values.\n&quot;,&#x000A;    &quot;Note: It is rarely used in output layers. For binary classification, Sigmoid is preferred (outputting 0~1 probabilities), and for multi-class classification, Softmax is used. Tanh is generally restricted to hidden layers.\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;tanh 函数核心是，能把任意实数映射到 -1 ~ 1 之间，且输出是 0 均值；\n&quot;,&#x000A;    &quot;主要用在深度学习隐藏层（尤其是早期序列模型），解决了 Sigmoid 非 0 均值的问题；\n&quot;,&#x000A;    &quot;最大缺点是仍存在梯度消失，计算成本也高于 ReLU，因此现在隐藏层主流还是用 ReLU。&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 7,&#x000A;   &quot;id&quot;: &quot;2e789b42&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [&#x000A;    {&#x000A;     &quot;data&quot;: {&#x000A;      &quot;image/svg+xml&quot;: [&#x000A;       &quot;&lt;?xml version=\&quot;1.0\&quot; encoding=\&quot;utf-8\&quot; standalone=\&quot;no\&quot;?&gt;\n&quot;,&#x000A;       &quot;&lt;!DOCTYPE svg PUBLIC \&quot;-//W3C//DTD SVG 1.1//EN\&quot;\n&quot;,&#x000A;       &quot;  \&quot;http://www.w3.org/Graphics/SVG/1.1/DTD/svg11.dtd\&quot;&gt;\n&quot;,&#x000A;       &quot;&lt;svg xmlns:xlink=\&quot;http://www.w3.org/1999/xlink\&quot; width=\&quot;338.360937pt\&quot; height=\&quot;183.35625pt\&quot; viewBox=\&quot;0 0 338.360937 183.35625\&quot; xmlns=\&quot;http://www.w3.org/2000/svg\&quot; version=\&quot;1.1\&quot;&gt;\n&quot;,&#x000A;       &quot; &lt;metadata&gt;\n&quot;,&#x000A;       &quot;  &lt;rdf:RDF xmlns:dc=\&quot;http://purl.org/dc/elements/1.1/\&quot; xmlns:cc=\&quot;http://creativecommons.org/ns#\&quot; xmlns:rdf=\&quot;http://www.w3.org/1999/02/22-rdf-syntax-ns#\&quot;&gt;\n&quot;,&#x000A;       &quot;   &lt;cc:Work&gt;\n&quot;,&#x000A;       &quot;    &lt;dc:type rdf:resource=\&quot;http://purl.org/dc/dcmitype/StillImage\&quot;/&gt;\n&quot;,&#x000A;       &quot;    &lt;dc:date&gt;2026-03-19T04:29:02.838350&lt;/dc:date&gt;\n&quot;,&#x000A;       &quot;    &lt;dc:format&gt;image/svg+xml&lt;/dc:format&gt;\n&quot;,&#x000A;       &quot;    &lt;dc:creator&gt;\n&quot;,&#x000A;       &quot;     &lt;cc:Agent&gt;\n&quot;,&#x000A;       &quot;      &lt;dc:title&gt;Matplotlib v3.7.5, https://matplotlib.org/&lt;/dc:title&gt;\n&quot;,&#x000A;       &quot;     &lt;/cc:Agent&gt;\n&quot;,&#x000A;       &quot;    &lt;/dc:creator&gt;\n&quot;,&#x000A;       &quot;   &lt;/cc:Work&gt;\n&quot;,&#x000A;       &quot;  &lt;/rdf:RDF&gt;\n&quot;,&#x000A;       &quot; &lt;/metadata&gt;\n&quot;,&#x000A;       &quot; &lt;defs&gt;\n&quot;,&#x000A;       &quot;  &lt;style type=\&quot;text/css\&quot;&gt;*{stroke-linejoin: round; stroke-linecap: butt}&lt;/style&gt;\n&quot;,&#x000A;       &quot; &lt;/defs&gt;\n&qu