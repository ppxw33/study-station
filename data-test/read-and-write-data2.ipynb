  1.3803, -1.2335, -1.9188, -0.5187, -0.0557,  1.4436,  0.3204,\n","          1.3069,  0.9539, -0.5700,  0.1128, -0.0701, -1.6358, -0.4887,  0.7973,\n","          1.7444,  1.3317,  0.3480,  0.6144],\n","        [ 0.3788, -1.2145,  1.8238, -0.3138,  0.8632, -1.3183,  0.1230,  0.0937,\n","          0.2691,  0.2246,  0.0783,  2.8819, -0.1049, -0.6857, -0.7599,  1.1414,\n","          0.1712, -0.7345, -0.3729,  0.0895,  1.2941, -2.0278,  0.4062, -2.5170,\n","         -0.4702, -1.3386,  0.1697,  0.5282, -2.0054,  0.5684,  2.4788, -0.3586,\n","         -0.7180,  1.3970,  0.7464,  0.3179, -1.0070, -1.1622,  0.5543,  1.5379,\n","          1.0479,  0.0056,  0.1405,  2.0187,  1.0903, -2.0557,  0.5912,  1.7424,\n","          0.6990, -0.0463,  1.2711,  0.0878,  1.0322, -2.2458,  1.4628,  1.3038,\n","         -0.3198,  1.3258,  0.6744, -0.1163,  0.0971, -0.1927,  0.1322,  0.0329,\n","         -0.2117, -0.9383,  1.1098,  0.6806, -0.4700, -1.2459,  0.8520,  0.8948,\n","         -1.3556,  0.1435,  0.5262,  0.8694,  2.6826, -0.6499,  0.2963,  1.2258,\n","         -1.3148,  0.7663, -0.5392, -0.2978,  0.4343, -2.6244, -0.9712,  0.8788,\n","         -0.2693,  1.2202,  1.5565, -0.1650,  2.2297, -0.7077,  0.7761,  0.2068,\n","          0.5215, -0.7519, -0.5227, -0.8698]])\n","标签 y 前2行：\n","tensor([[-8.9567],\n","        [11.4502]])\n"]}],"source":["#file path:~/Desktop/study-station/data-test/training_data.csv\n","file_path = \"~/Desktop/study-station/data-test/training_data.csv\"\n","#替换标签列名赋给变量label_column\n","label_column = \"labels\"\n","#try关键字，它与except、else、finally等关键字配合使用，构成try-except语句块，用于捕获和处理程序运行是时可能出现的错误，从而避免程序因未处理的异常而崩溃\n","#基本原理，当程序执行到try时，会尝试运行其中的代码。运行成功会跳过except块，否则立即停止运行try中的代码，并寻找except块来处理错误\n","#try块：包含可能会引发异常的代码\n","#except块：捕获特定异常，可以有多个不同异常类型\n","#else块：可选，如果如果try中的代码可以执行，则会执行else中的代码\n","#finally块：无论try代码是否发生异常，也无论异常是否捕获，都会执行finally中的代码，常用于执行清理操作\n","try:\n","    #read file \n","    df = pd.read_csv(\n","        file_path,\n","        encoding=\"utf-8\", # 编码，中文文件常用 utf-8 / gbk\n","        sep=\",\",            # 分隔符，默认是逗号，可根据文件调整（如\\t、;）\n","        header=0            # 指定第0行（第一行）为列名，无列名则设为 header=None\n","     )\n","    \n","    # 分离特征 X 和标签 y\n","    # 特征：所有列排除标签列\n","    # .drop()：pandas 的删除方法，作用是「移除指定的列 / 行」，这里用来删掉标签列，只保留特征列\n","    # columns=[label_column]：指定要删除的是「列」，且删除的列名是 label_column（比如你定义的 \"label\" 或 \"标签\"）；\n","    X_df = df.drop(columns=[label_column])\n","    # 标签：仅保留标签列\n","    y_df = df[[label_column]]\n","    \n","    # .fillna()：pandas 的「填充空值」方法，作用是把数据中的所有 NaN 替换成指定值；\n","    # X_df.mean()：计算 X_df 中每一列的均值（比如特征 1 列的所有非空值求平均，特征 2 列同理）；\n","    # 数据预处理（关键：处理缺失值，张量不允许NaN）\n","    # 特征填充缺失值（用列均值，也可改为0：fillna(0)）\n","    X_df = X_df.fillna(X_df.mean())\n","    # 标签填充缺失值（分类标签用众数，回归标签用均值，这里以均值为例）\n","    y_df = y_df.fillna(y_df.mean())\n","    \n","    # .values 是 pandas 的属性，作用是把数据框从「表格格式」转换成 NumPy 数组\n","    # 转换为 PyTorch 张量（核心步骤）\n","    # 特征张量：shape=(10000, 100) → 1万行，每行100个元素\n","    X = torch.tensor(X_df.values, dtype=torch.float32)\n","    # 标签张量：shape=(10000, 1) → 1万行，每行1个元素（若要一维则用 y_df.values.flatten()）\n","    y = torch.tensor(y_df.values, dtype=torch.float32)  # 分类任务可改为 torch.long\n","    \n","     # 6. 验证张量形状（确保符合要求）\n","    print(\"\\n=== 张量形状验证 ===\")\n","    print(f\"特征张量 X 形状：{X.shape}（预期 (10000, 100)）\")\n","    print(f\"标签张量 y 形状：{y.shape}（预期 (10000, 1)）\")\n","    \n","    # 打印前2行数据，直观验证\n","    print(\"\\n=== 前2行数据示例 ===\")\n","    print(\"特征 X 前2行：\")\n","    print(X[:2])\n","    print(\"标签 y 前2行：\")\n","    print(y[:2])\n","    \n","except FileNotFoundError:\n","    print(f\"错误：找不到文件 {file_path}，请检查路径是否正确\")\n","except KeyError:\n","    print(f\"错误：标签列名 '{label_column}' 不存在，请核对列名\")\n","except ValueError as e:\n","    print(f\"数据格式错误：{e}\")\n","except UnicodeDecodeError:\n","    print(\"错误：编码格式不匹配，尝试将 encoding 改为 'gbk' 或 'gb2312'\")\n","except Exception as e:\n","    print(f\"读取失败：{e}\")"]},{"cell_type":"code","execution_count":4,"id":"a4c4ad35","metadata":{},"outputs":[],"source":["#这里将X，y重新赋值给特征features和标签labels便接上了实验内容\n","features = X\n","labels = y"]},{"cell_type":"markdown","id":"bc795da1","metadata":{},"source":"\u003Cp\u003EHere we conclude the required content.Next,referring to section 3.3,we will complete the final training work\u003C/p\u003E\n\u003Cp\u003E到这里便完成了要求内容，接下来参考3.3节，完成最后的训练工作\u003C/p\u003E"},{"cell_type":"code","execution_count":5,"id":"0b37f918","metadata":{},"outputs":[],"source":["def load_array(data_arrays, batch_size, is_train=True):  #@save\n","    \"\"\"构造一个PyTorch数据迭代器\"\"\"\n","    dataset = data.TensorDataset(*data_arrays)\n","    return data.DataLoader(dataset, batch_size, shuffle=is_train)"]},{"cell_type":"code","execution_count":6,"id":"be6216aa","metadata":{},"outputs":[],"source":["batch_size = 100\n","data_iter = load_array((features, labels), batch_size)"]},{"cell_type":"code","execution_count":7,"id":"b6860553","metadata":{},"outputs":[],"source":["#next(iter(data_iter))"]},{"cell_type":"code","execution_count":8,"id":"719efb51","metadata":{},"outputs":[],"source":["from torch import nn\n","\n","net = nn.Sequential(nn.Linear(100, 1))"]},{"cell_type":"code","execution_count":9,"id":"5655a8fc","metadata":{},"outputs":[{"data":{"text/plain":["tensor([-0.0140])"]},"execution_count":9,"metadata":{},"output_type":"execute_result"}],"source":["net[0].weight.data.normal_(0, 0.01)\n","net[0].bias.data.normal_(0,0.01)"]},{"cell_type":"code","execution_count":10,"id":"b8a6c7da","metadata":{},"outputs":[],"source":["loss = nn.MSELoss()"]},{"cell_type":"code","execution_count":11,"id":"bd2c90f2","metadata":{},"outputs":[],"source":["trainer = torch.optim.SGD(net.parameters(), lr=0.03)"]},{"cell_type":"code","execution_count":12,"id":"186ff720","metadata":{},"outputs":[{"name":"stdout","output_type":"stream","text":["epoch 1, loss 0.944692\n","epoch 2, loss 0.945508\n","epoch 3, loss 0.942358\n","epoch 4, loss 0.947923\n","epoch 5, loss 0.945285\n","epoch 6, loss 0.947718\n","epoch 7, loss 0.947734\n","epoch 8, loss 0.943484\n","epoch 9, loss 0.945092\n","epoch 10, loss 0.942130\n"]}],"source":["num_epochs = 10\n","for epoch in range(num_epochs):\n","    for X, y in data_iter:\n","        l = loss(net(X) ,y)\n","        trainer.zero_grad()\n","        l.backward()\n","        trainer.step()\n","    l = loss(net(features), labels)\n","    print(f'epoch {epoch + 1}, loss {l:f}')"]},{"cell_type":"markdown","id":"c4e5c418","metadata":{},"source":"\u003Cp\u003EHere,following the writing style of the previous section,continue to read and convert the true weights w and bias b,with the source path being the previously generated file 'answer_true.csv'\u003C/p\u003E\n\u003Cp\u003E这里参照上部分写法，继续读取并转化真实权重w和偏置b，来源路径为上次生成的文件answer_true.csv\u003C/p\u003E"},{"cell_type":"code","execution_count":16,"id":"956e940e","metadata":{},"outputs":[],"source":["file_path = \"~/Desktop/study-station/data-test/answer_true.csv\"\n","answer_b = \"true_b\"\n","try:\n","    #read file \n","    df = pd.read_csv(\n","        file_path,\n","        encoding=\"utf-8\", \n","        sep=\",\",            \n","        header=0            \n","     )\n","    \n","    w_df = df.drop(columns=[answer_b])\n","    b_df = df[[answer_b]]\n","    \n","    # 数据预处理（关键：处理缺失值，张量不允许NaN）\n","    # 特征填充缺失值（用列均值，也可改为0：fillna(0)）\n","    w_df = w_df.fillna(w_df.mean())\n","    # 标签填充缺失值（分类标签用众数，回归标签用均值，这里以均值为例）\n","    b_df = w_df.fillna(w_df.mean())\n","    \n","    # .values 是 pandas 的属性，作用是把数据框从「表格格式」转换成 NumPy 数组\n","    # 转换为 PyTorch 张量（核心步骤）\n","    # 特征张量：shape=(10000, 100) → 1万行，每行100个元素\n","    true_w = torch.tensor(w_df.values, dtype=torch.float32)\n","    # 标签张量：shape=(10000, 1) → 1万行，每行1个元素（若要一维则用 y_df.values.flatten()）\n","    true_b = torch.tensor(b_df.values, dtype=torch.float32)  # 分类任务可改为 torch.long\n","    # 把多维张量数组压平成一维\n","    true_w = true_w.flatten()\n","    # pytorch中专门用来“重塑张量形状”的函数(-1)展平成一维\n","    true_b = true_b.view(-1)\n","    \n","except FileNotFoundError:\n","    print(f\"错误：找不到文件 {file_path}，请检查路径是否正确\")\n","except Key