\u003C/g\u003E\n","   \u003Cg id=\"line2d_29\"\u003E\n","    \u003Cpath d=\"M 46.922443 139.5 \n","L 174.538227 139.5 \n","L 300.558807 13.5 \n","L 300.558807 13.5 \n","\" clip-path=\"url(#p407ec59d2e)\" style=\"fill: none; stroke: #1f77b4; stroke-width: 1.5; stroke-linecap: square\"/\u003E\n","   \u003C/g\u003E\n","   \u003Cg id=\"patch_3\"\u003E\n","    \u003Cpath d=\"M 34.240625 145.8 \n","L 34.240625 7.2 \n","\" style=\"fill: none; stroke: #000000; stroke-width: 0.8; stroke-linejoin: miter; stroke-linecap: square\"/\u003E\n","   \u003C/g\u003E\n","   \u003Cg id=\"patch_4\"\u003E\n","    \u003Cpath d=\"M 313.240625 145.8 \n","L 313.240625 7.2 \n","\" style=\"fill: none; stroke: #000000; stroke-width: 0.8; stroke-linejoin: miter; stroke-linecap: square\"/\u003E\n","   \u003C/g\u003E\n","   \u003Cg id=\"patch_5\"\u003E\n","    \u003Cpath d=\"M 34.240625 145.8 \n","L 313.240625 145.8 \n","\" style=\"fill: none; stroke: #000000; stroke-width: 0.8; stroke-linejoin: miter; stroke-linecap: square\"/\u003E\n","   \u003C/g\u003E\n","   \u003Cg id=\"patch_6\"\u003E\n","    \u003Cpath d=\"M 34.240625 7.2 \n","L 313.240625 7.2 \n","\" style=\"fill: none; stroke: #000000; stroke-width: 0.8; stroke-linejoin: miter; stroke-linecap: square\"/\u003E\n","   \u003C/g\u003E\n","  \u003C/g\u003E\n"," \u003C/g\u003E\n"," \u003Cdefs\u003E\n","  \u003CclipPath id=\"p407ec59d2e\"\u003E\n","   \u003Crect x=\"34.240625\" y=\"7.2\" width=\"279\" height=\"138.6\"/\u003E\n","  \u003C/clipPath\u003E\n"," \u003C/defs\u003E\n","\u003C/svg\u003E\n"],"text/plain":["\u003CFigure size 500x250 with 1 Axes\u003E"]},"metadata":{},"output_type":"display_data"}],"source":["# .arange生成一维等差数列张量,起始值 =-8.0，终止值（不包含）=8.0，步长 = 0.1，最终生成 [-8.0, -7.9, ..., 7.9]\n","# .requires_grad=True,关键参数：开启张量的梯度追踪功能，后续对 x 做运算时会记录计算图，支持求导\n","x = torch.arange(-8.0, 8.0, 0.1, requires_grad=True)\n","# y = torch.relu(x) 是 PyTorch 框架中对张量 x 应用 ReLU 激活函数 的核心语句\n","y = torch.relu(x)\n","# 是调用 d2l（动手学深度学习）库的绘图函数，可视化 ReLU 函数的输入输出关系\n","# detach() 切断张量的计算图关联，将其转换为 “普通张量”（避免梯度计算干扰，同时让 Matplotlib 能识别）\n","# figsize=(5, 2.5)\t设置图表的尺寸：宽度 5 英寸，高度 2.5 英寸（控制图表大小，避免过大 / 过小）\n","d2l.plot(x.detach(), y.detach(), 'x', 'relu(x)', figsize=(5, 2.5))"]},{"cell_type":"markdown","id":"544b3a39","metadata":{},"source":"\u003Cp\u003E当输入为负时，ReLU函数的导数为0，而当输入为正时，ReLU函数的导数为1。\n注意，当输入值精确等于0时，ReLU函数不可导。\n在此时，我们默认使用左侧的导数，即当输入为0时导数为0。\n我们可以忽略这种情况，因为输入可能永远都不会是0。\n这里引用一句古老的谚语，“如果微妙的边界条件很重要，我们很可能是在研究数学而非工程”，\n这个观点正好适用于这里。\n下面我们绘制ReLU函数的导数。\u003C/p\u003E"},{"cell_type":"code","execution_count":4,"id":"85488689","metadata":{},"outputs":[{"data":{"image/svg+xml":["\u003C?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"no\"?\u003E\n","\u003C!DOCTYPE svg PUBLIC \"-//W3C//DTD SVG 1.1//EN\"\n","  \"http://www.w3.org/Graphics/SVG/1.1/DTD/svg11.dtd\"\u003E\n","\u003Csvg xmlns:xlink=\"http://www.w3.org/1999/xlink\" width=\"329.98125pt\" height=\"183.35625pt\" viewBox=\"0 0 329.98125 183.35625\" xmlns=\"http://www.w3.org/2000/svg\" version=\"1.1\"\u003E\n"," \u003Cmetadata\u003E\n","  \u003Crdf:RDF xmlns:dc=\"http://purl.org/dc/elements/1.1/\" xmlns:cc=\"http://creativecommons.org/ns#\" xmlns:rdf=\"http://www.w3.org/1999/02/22-rdf-syntax-ns#\"\u003E\n","   \u003Ccc:Work\u003E\n","    \u003Cdc:type rdf:resource=\"http://purl.org/dc/dcmitype/StillImage\"/\u003E\n","    \u003Cdc:date\u003E2026-03-19T02:46:27.226476\u003C/dc:date\u003E\n","    \u003Cdc:format\u003Eimage/svg+xml\u003C/dc:format\u003E\n","    \u003Cdc:creator\u003E\n","     \u003Ccc:Agent\u003E\n","      \u003Cdc:title\u003EMatplotlib v3.7.5, https://matplotlib.org/\u003C/dc:title\u003E\n","     \u003C/cc:Agent\u003E\n","    \u003C/dc:creator\u003E\n","   \u003C/cc:Work\u003E\n","  \u003C/rdf:RDF\u003E\n"," \u003C/metadata\u003E\n"," \u003Cdefs\u003E\n","  \u003Cstyle type=\"text/css\"\u003E*{stroke-linejoin: round; stroke-linecap: butt}\u003C/style\u003E\n"," \u003C/defs\u003E\n"," \u003Cg id=\"figure_1\"\u003E\n","  \u003Cg id=\"patch_1\"\u003E\n","   \u003Cpath d=\"M 0 