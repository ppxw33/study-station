k\n&quot;,&#x000A;    &quot;        sep=\&quot;,\&quot;,            # 分隔符，默认是逗号，可根据文件调整（如\\t、;）\n&quot;,&#x000A;    &quot;        header=0            # 指定第0行（第一行）为列名，无列名则设为 header=None\n&quot;,&#x000A;    &quot;     )\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;    # 分离特征 X 和标签 y\n&quot;,&#x000A;    &quot;    # 特征：所有列排除标签列\n&quot;,&#x000A;    &quot;    # .drop()：pandas 的删除方法，作用是「移除指定的列 / 行」，这里用来删掉标签列，只保留特征列\n&quot;,&#x000A;    &quot;    # columns=[label_column]：指定要删除的是「列」，且删除的列名是 label_column（比如你定义的 \&quot;label\&quot; 或 \&quot;标签\&quot;）；\n&quot;,&#x000A;    &quot;    X_df = df.drop(columns=[label_column])\n&quot;,&#x000A;    &quot;    # 标签：仅保留标签列\n&quot;,&#x000A;    &quot;    y_df = df[[label_column]]\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;    # .fillna()：pandas 的「填充空值」方法，作用是把数据中的所有 NaN 替换成指定值；\n&quot;,&#x000A;    &quot;    # X_df.mean()：计算 X_df 中每一列的均值（比如特征 1 列的所有非空值求平均，特征 2 列同理）；\n&quot;,&#x000A;    &quot;    # 数据预处理（关键：处理缺失值，张量不允许NaN）\n&quot;,&#x000A;    &quot;    # 特征填充缺失值（用列均值，也可改为0：fillna(0)）\n&quot;,&#x000A;    &quot;    X_df = X_df.fillna(X_df.mean())\n&quot;,&#x000A;    &quot;    # 标签填充缺失值（分类标签用众数，回归标签用均值，这里以均值为例）\n&quot;,&#x000A;    &quot;    y_df = y_df.fillna(y_df.mean())\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;    # .values 是 pandas 的属性，作用是把数据框从「表格格式」转换成 NumPy 数组\n&quot;,&#x000A;    &quot;    # 转换为 PyTorch 张量（核心步骤）\n&quot;,&#x000A;    &quot;    # 特征张量：shape=(10000, 100) → 1万行，每行100个元素\n&quot;,&#x000A;    &quot;    X = torch.tensor(X_df.values, dtype=torch.float32)\n&quot;,&#x000A;    &quot;    # 标签张量：shape=(10000, 1) → 1万行，每行1个元素（若要一维则用 y_df.values.flatten()）\n&quot;,&#x000A;    &quot;    y = torch.tensor(y_df.values, dtype=torch.float32)  # 分类任务可改为 torch.long\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;     # 6. 验证张量形状（确保符合要求）\n&quot;,&#x000A;    &quot;    print(\&quot;\\n=== 张量形状验证 ===\&quot;)\n&quot;,&#x000A;    &quot;    print(f\&quot;特征张量 X 形状：{X.shape}（预期 (10000, 100)）\&quot;)\n&quot;,&#x000A;    &quot;    print(f\&quot;标签张量 y 形状：{y.shape}（预期 (10000, 1)）\&quot;)\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;    # 打印前2行数据，直观验证\n&quot;,&#x000A;    &quot;    print(\&quot;\\n=== 前2行数据示例 ===\&quot;)\n&quot;,&#x000A;    &quot;    print(\&quot;特征 X 前2行：\&quot;)\n&quot;,&#x000A;    &quot;    print(X[:2])\n&quot;,&#x000A;    &quot;    print(\&quot;标签 y 前2行：\&quot;)\n&quot;,&#x000A;    &quot;    print(y[:2])\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;except FileNotFoundError:\n&quot;,&#x000A;    &quot;    print(f\&quot;错误：找不到文件 {file_path}，请检查路径是否正确\&quot;)\n&quot;,&#x000A;    &quot;except KeyError:\n&quot;,&#x000A;    &quot;    print(f\&quot;错误：标签列名 &#39;{label_column}&#39; 不存在，请核对列名\&quot;)\n&quot;,&#x000A;    &quot;except ValueError as e:\n&quot;,&#x000A;    &quot;    print(f\&quot;数据格式错误：{e}\&quot;)\n&quot;,&#x000A;    &quot;except UnicodeDecodeError:\n&quot;,&#x000A;    &quot;    print(\&quot;错误：编码格式不匹配，尝试将 encoding 改为 &#39;gbk&#39; 或 &#39;gb2312&#39;\&quot;)\n&quot;,&#x000A;    &quot;except Exception as e:\n&quot;,&#x000A;    &quot;    print(f\&quot;读取失败：{e}\&quot;)&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 4,&#x000A;   &quot;id&quot;: &quot;a4c4ad35&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;#这里将X，y重新赋值给特征features和标签labels便接上了实验内容\n&quot;,&#x000A;    &quot;features = X\n&quot;,&#x000A;    &quot;labels = y&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;markdown&quot;,&#x000A;   &quot;id&quot;: &quot;bc795da1&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;source&quot;: [&#x000A;    &quot;Here we conclude the required content.Next,referring to section 3.3,we will complete the final training work\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;到这里便完成了要求内容，接下来参考3.3节，完成最后的训练工作&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 5,&#x000A;   &quot;id&quot;: &quot;0b37f918&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;def load_array(data_arrays, batch_size, is_train=True):  #@save\n&quot;,&#x000A;    &quot;    \&quot;\&quot;\&quot;构造一个PyTorch数据迭代器\&quot;\&quot;\&quot;\n&quot;,&#x000A;    &quot;    dataset = data.TensorDataset(*data_arrays)\n&quot;,&#x000A;    &quot;    return data.DataLoader(dataset, batch_size, shuffle=is_train)&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 6,&#x000A;   &quot;id&quot;: &quot;be6216aa&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;batch_size = 100\n&quot;,&#x000A;    &quot;data_iter = load_array((features, labels), batch_size)&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 7,&#x000A;   &quot;id&quot;: &quot;b6860553&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;#next(iter(data_iter))&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 8,&#x000A;   &quot;id&quot;: &quot;719efb51&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;from torch import nn\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;net = nn.Sequential(nn.Linear(100, 1))&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 9,&#x000A;   &quot;id&quot;: &quot;5655a8fc&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [&#x000A;    {&#x000A;     &quot;data&quot;: {&#x000A;      &quot;text/plain&quot;: [&#x000A;       &quot;tensor([-0.0140])&quot;&#x000A;      ]&#x000A;     },&#x000A;     &quot;execution_count&quot;: 9,&#x000A;     &quot;metadata&quot;: {},&#x000A;     &quot;output_type&quot;: &quot;execute_result&quot;&#x000A;    }&#x000A;   ],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;net[0].weight.data.normal_(0, 0.01)\n&quot;,&#x000A;    &quot;net[0].bias.data.normal_(0,0.01)&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 10,&#x000A;   &quot;id&quot;: &quot;b8a6c7da&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;loss = nn.MSELoss()&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 11,&#x000A;   &quot;id&quot;: &quot;bd2c90f2&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;trainer = torch.optim.SGD(net.parameters(), lr=0.03)&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 12,&#x000A;   &quot;id&quot;: &quot;186ff720&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [&#x000A;    {&#x000A;     &quot;name&quot;: &quot;stdout&quot;,&#x000A;     &quot;output_type&quot;: &quot;stream&quot;,&#x000A;     &quot;text&quot;: [&#x000A;      &quot;epoch 1, loss 0.944692\n&quot;,&#x000A;      &quot;epoch 2, loss 0.945508\n&quot;,&#x000A;      &quot;epoch 3, loss 0.942358\n&quot;,&#x000A;      &quot;epoch 4, loss 0.947923\n&quot;,&#x000A;      &quot;epoch 5, loss 0.945285\n&quot;,&#x000A;      &quot;epoch 6, loss 0.947718\n&quot;,&#x000A;      &quot;epoch 7, loss 0.947734\n&quot;,&#x000A;      &quot;epoch 8, loss 0.943484\n&quot;,&#x000A;      &quot;epoch 9, loss 0.945092\n&quot;,&#x000A;      &quot;epoch 10, loss 0.942130\n&quot;&#x000A;     ]&#x000A;    }&#x000A;   ],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;num_epochs = 10\n&quot;,&#x000A;    &quot;for epoch in range(num_epochs):\n&quot;,&#x000A;    &quot;    for X, y in data_iter:\n&quot;,&#x000A;    &quot;        l = loss(net(X) ,y)\n&quot;,&#x000A;    &quot;        trainer.zero_grad()\n&quot;,&#x000A;    &quot;        l.backward()\n&quot;,&#x000A;    &quot;        trainer.step()\n&quot;,&#x000A;    &quot;    l = loss(net(features), labels)\n&quot;,&#x000A;    &quot;    print(f&#39;epoch {epoch + 1}, loss {l:f}&#39;)&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;markdown&quot;,&#x000A;   &quot;id&quot;: &quot;c4e5c418&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;source&quot;: [&#x000A;    &quot;Here,following the writing style of the previous section,continue to read and convert the true weights w and bias b,with the source path being the previously generated file &#39;answer_true.csv&#39;\n&quot;,&#x000A;    &quot;\n&quot;,&#x000A;    &quot;这里参照上部分写法，继续读取并转化真实权重w和偏置b，来源路径为上次生成的文件answer_true.csv&quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;code&quot;,&#x000A;   &quot;execution_count&quot;: 16,&#x000A;   &quot;id&quot;: &quot;956e940e&quot;,&#x000A;   &quot;metadata&quot;: {},&#x000A;   &quot;outputs&quot;: [],&#x000A;   &quot;source&quot;: [&#x000A;    &quot;file_path = \&quot;~/Desktop/study-station/data-test/answer_true.csv\&quot;\n&quot;,&#x000A;    &quot;answer_b = \&quot;true_b\&quot;\n&quot;,&#x000A;    &quot;try:\n&quot;,&#x000A;    &quot;    #read file \n&quot;,&#x000A;    &quot;    df = pd.read_csv(\n&quot;,&#x000A;    &quot;        file_path,\n&quot;,&#x000A;    &quot;        encoding=\&quot;utf-8\&quot;, \n&quot;,&#x000A;    &quot;        sep=\&quot;,\&quot;,            \n&quot;,&#x000A;    &quot;        header=0            \n&quot;,&#x000A;    &quot;     )\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;    w_df = df.drop(columns=[answer_b])\n&quot;,&#x000A;    &quot;    b_df = df[[answer_b]]\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;    # 数据预处理（关键：处理缺失值，张量不允许NaN）\n&quot;,&#x000A;    &quot;    # 特征填充缺失值（用列均值，也可改为0：fillna(0)）\n&quot;,&#x000A;    &quot;    w_df = w_df.fillna(w_df.mean())\n&quot;,&#x000A;    &quot;    # 标签填充缺失值（分类标签用众数，回归标签用均值，这里以均值为例）\n&quot;,&#x000A;    &quot;    b_df = w_df.fillna(w_df.mean())\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;    # .values 是 pandas 的属性，作用是把数据框从「表格格式」转换成 NumPy 数组\n&quot;,&#x000A;    &quot;    # 转换为 PyTorch 张量（核心步骤）\n&quot;,&#x000A;    &quot;    # 特征张量：shape=(10000, 100) → 1万行，每行100个元素\n&quot;,&#x000A;    &quot;    true_w = torch.tensor(w_df.values, dtype=torch.float32)\n&quot;,&#x000A;    &quot;    # 标签张量：shape=(10000, 1) → 1万行，每行1个元素（若要一维则用 y_df.values.flatten()）\n&quot;,&#x000A;    &quot;    true_b = torch.tensor(b_df.values, dtype=torch.float32)  # 分类任务可改为 torch.long\n&quot;,&#x000A;    &quot;    # 把多维张量数组压平成一维\n&quot;,&#x000A;    &quot;    true_w = true_w.flatten()\n&quot;,&#x000A;    &quot;    # pytorch中专门用来“重塑张量形状”的函数(-1)展平成一维\n&quot;,&#x000A;    &quot;    true_b = true_b.view(-1)\n&quot;,&#x000A;    &quot;    \n&quot;,&#x000A;    &quot;except FileNotFoundError:\n&quot;,&#x000A;    &quot;    print(f\&quot;错误：找不到文件 {file_path}，请检查路径是否正确\&quot;)\n&quot;,&#x000A;    &quot;except KeyError:\n&quot;,&#x000A;    &quot;    print(f\&quot;错误：标签列名 &#39;{label_column}&#39; 不存在，请核对列名\&quot;)\n&quot;,&#x000A;    &quot;except ValueError as e:\n&quot;,&#x000A;    &quot;    print(f\&quot;数据格式错误：{e}\&quot;)\n&quot;,&#x000A;    &quot;except UnicodeDecodeError:\n&quot;,&#x000A;    &quot;    print(\&quot;错误：编码格式不匹配，尝试将 encoding 改为 &#39;gbk&#39; 或 &#39;gb2312&#39;\&quot;)\n&quot;,&#x000A;    &quot;except Exception as e:\n&quot;,&#x000A;    &quot;    print(f\&quot;读取失败：{e}\&quot;)\n&quot;,&#x000A;    &quot;    &quot;&#x000A;   ]&#x000A;  },&#x000A;  {&#x000A;   &quot;cell_type&quot;: &quot;co